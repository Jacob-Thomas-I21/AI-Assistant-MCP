# ── Provider ───────────────────────────────────────────────────────────────────
# Which backend to use: openrouter | openai | anthropic
LLM_PROVIDER=openrouter

# ── OpenRouter ─────────────────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai
# Gives access to all models below through a single API key.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Direct OpenAI ──────────────────────────────────────────────────────────────
# Only needed if LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

# ── Direct Anthropic ───────────────────────────────────────────────────────────
# Only needed if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Models ─────────────────────────────────────────────────────────────────────
# PROD_MODEL is used by all agents. DEV_MODEL is available for lightweight calls.
# Prefix depends on provider:
#   openrouter  -> anthropic/claude-sonnet-4.5 | openai/gpt-4o-mini
#   openai      -> gpt-4o | gpt-4o-mini
#   anthropic   -> claude-sonnet-4-20250514 | claude-haiku-3-5
PROD_MODEL=anthropic/claude-sonnet-4.5
DEV_MODEL=openai/gpt-4o-mini

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Always via OpenRouter unless you add a separate embedding provider.
# EMBEDDING_MODEL=openai/text-embedding-3-small

# ── RAG tuning (optional overrides) ───────────────────────────────────────────
# CHUNK_SIZE=500
# CHUNK_OVERLAP=100
# TOP_K=5
# CONFIDENCE_THRESHOLD=0.35
